# Optional ArcGIS Developer API key for Esri Wayback tiles.
# Anonymous requests work for hackathon-scale traffic. Set this only if you
# hit 429 rate-limit errors or want to raise the quota to 1M tile requests
# per month on the free ArcGIS Developer tier.
#
# How to obtain:
#   1. Create a free account at https://developers.arcgis.com/
#   2. Generate an API key with the "Basemap layers" scope
#   3. Copy it below and restart `npm run dev` (Next.js bakes
#      NEXT_PUBLIC_* env vars into the client bundle at build time).
#
# Leave empty (or unset) to keep anonymous Wayback access.
NEXT_PUBLIC_ARCGIS_API_KEY=
